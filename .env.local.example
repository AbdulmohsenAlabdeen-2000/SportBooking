# Smash Courts Kuwait — environment variables
# Copy to .env.local and fill in the real values. Never commit .env.local.

# Supabase project (Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key  # SERVER-ONLY — never ship in a client bundle

# Public site URL — used by sitemap.xml and absolute Open Graph links.
# Local: http://localhost:3000   Production: https://your-domain
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Shared secret for the daily slot-ensure cron. Vercel Cron sends
# `Authorization: Bearer ${CRON_SECRET}`. Generate with:
#   openssl rand -hex 32
CRON_SECRET=replace-with-a-long-random-string

# Twilio — sends booking confirmation SMS (separate from Supabase Auth's
# OTP integration). Without these vars the SMS step is skipped silently;
# bookings still go through. Trial accounts only deliver to Verified
# Caller IDs — upgrade Twilio to send to arbitrary numbers.
# Get from Twilio Console → Account → API keys & tokens.
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-twilio-auth-token
# Sender: either an E.164 phone number ("+12025551234") OR a Messaging
# Service SID ("MGxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx").
TWILIO_FROM=+12025551234

# (The customer support chat widget and the conversational booking
# surfaces all use OpenRouter — see OPENROUTER_API_KEY below.)

# OpenRouter — powers the conversational booking surfaces (/book/chat
# and /admin/assistant). OpenRouter is an OpenAI-compatible aggregator;
# any of its models can be used by changing OPENROUTER_MODEL. Get a key
# from https://openrouter.ai/keys.
OPENROUTER_API_KEY=sk-or-...
# Optional — defaults to anthropic/claude-3.5-sonnet.
# OPENROUTER_MODEL=anthropic/claude-3.5-sonnet

# Admin MCP — lets Claude Desktop / Code drive the admin surface via
# tools/admin-mcp/. Generate with `openssl rand -hex 32` and set the
# same value on Vercel and in your Claude MCP server config.
ADMIN_MCP_TOKEN=

# Resend — sends booking confirmation emails (separate from SMS).
# Get a key at https://resend.com/api-keys. Without these vars the
# email step is skipped silently and bookings still work.
RESEND_API_KEY=re_...
# Sender. Must be a verified domain on your Resend account, OR
# leave it as `onboarding@resend.dev` for testing (Resend's free
# sandbox sender — works without DNS setup).
RESEND_FROM=Smash Courts <onboarding@resend.dev>
